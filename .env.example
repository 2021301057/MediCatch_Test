# ── 데이터베이스 ────────────────────────────────────
MYSQL_ROOT_PASSWORD=medicatch123

# ── JWT ───────────────────────────────────────────
JWT_SECRET=medicatch-jwt-secret-key-2026-change-in-production

# ── CODEF API ─────────────────────────────────────
# https://developer.codef.io 에서 발급
CODEF_API_CLIENT_ID=your_codef_api_client_id
CODEF_API_CLIENT_SECRET=your_codef_api_client_secret
CODEF_DEMO_CLIENT_ID=your_codef_demo_client_id
CODEF_DEMO_CLIENT_SECRET=your_codef_demo_client_secret
CODEF_PUBLIC_KEY=your_codef_rsa_public_key
CODEF_USE_DEMO=true

# ── OpenAI API (건강 채팅 AI) ─────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-your_openai_api_key

# ── RabbitMQ ──────────────────────────────────────
